(defcfg
  process-unmapped-keys yes
)

(defvar
  tap-time 150    ;; Shorter tap time for quick presses
  hold-time 250   ;; Longer hold time to ensure layer switch
)

(defalias
  tq_ (layer-switch default_qwerty)
  tq (layer-switch qwerty_dispaced)
  tg (layer-switch graphite_rise)
  ts (layer-switch graphite_rise_test)
  tf (layer-switch tapio_expanded)
  spcm (tap-hold 200 200 spc (layer-toggle movesym))
  spcm_tap (tap-hold 200 200 (one-shot 1000 (layer-while-held movesym)) (layer-toggle movesym))
  fnum (
    tap-dance 300 (
      (tap-hold 100 100 (one-shot 1000 lshift) (layer-toggle fnum))
      (tap-hold 200 200 caps lshift)
    )
  )
  fnum_ (
    tap-dance 300 (
      (tap-hold 100 100 (one-shot 1000 lshift) (layer-toggle fnum_))
      (tap-hold 200 200 caps lshift)
    )
  )
  fnum* (
    tap-dance 300 (
      (tap-hold 100 100 spc (layer-toggle fnum))
      caps
    )
  )
  fnum*_ (
    tap-dance 300 (
      (tap-hold 100 100 spc (layer-toggle fnum_))
      caps
    )
  )
  spcm_ (tap-hold 200 200 spc (layer-toggle movesym_))
  csc (
    tap-dance 300 (
      (tap-hold 200 200 esc lctrl)
      (multi lctrl lshift)
      (multi lctrl lalt lshift)
    )
  )
  ctrl ( multi lctl (layer-toggle default_qwerty))
  shift (
    tap-dance 300 (
      (tap-hold 200 200 (one-shot 1000 lshift) lshift)
      (layer-toggle fnum)
    )
  )  ;; ctrl esc
  alt (
    tap-dance 300 (
      (tap-hold 200 200 ( one-shot 1000 (layer-while-held movesym) ) lalt)
      (layer-toggle emoji)
    )
  )  ;; ctrl esc
  @/ (tap-hold 200 200 (one-shot 1000 lshift) lshift)
  ; (tap-hold 200 200 ; (layer-toggle extra))
  ⏎ (tap-hold 200 200 ⏎ (layer-toggle extra))
  , (tap-hold 200 200 , (layer-toggle extra))
  ,s (macro , spc)
  k (tap-hold 200 200 k (layer-toggle extra))
  xt (tap-hold 200 200 x (layer-toggle extra))
  _⏎ (tap-hold 200 200 ⏎ (layer-toggle extra_))
  ' (tap-hold 200 200 ' (layer-toggle extra_))
  000 (tap-hold 200 200 (macro Digit0 Digit0 Digit0) (layer-toggle extra_))
  sl (macro ⇤ lshift ⇥ ) ;; select current line
  A4 (multi lalt f4)

  mu   (mwheel-up    50 120)
  md   (mwheel-down  50 120)
  ml   (mwheel-left  50 120)
  mr   (mwheel-right 50 120)
  mA    (movemouse-accel-up    1 1000 1 5)
  m<    (movemouse-accel-left  1 1000 1 5)
  mv    (movemouse-accel-down  1 1000 1 5)
  m>    (movemouse-accel-right 1 1000 1 5)
)


(defsrc
  `
  esc   1     2     3     4     5     6     7     8     9     0    -
  tab   q     w     e     r     t     y     u     i     o     p     [     ]     \
  caps   a     s     d     f     g     h     j     k     l     ;     '     ret
  lshift  z     x     c     v     b     n     m     ,     .     /    rshift
  lctrl lalt spc  ralt rctrl
)

(deflayer default_qwerty
  `
  esc   1     2     3     4     5     6     7     8     9     0    -
  tab   q     w     e     r     t     y     u     i     o     p     [     ]     \
  @csc   a     s     d     f     g     h     j     k     l     ;     '    @_⏎
  @shift  z     x     c     v     b     n     m     ,     .     /    rshift
  lctrl @alt @spcm_  @fnum_ @spcm_tap
)

(deflayer graphite_rise
`
  caps 1     2     3     4     5     6     7     8     @,s  ;    -
  tab  b     l     d     w     q     [     '     f     o     u     j     S-;   S-'
  @csc  n     r     t     s     g     ;     y     h     a     e     i     @⏎
  @shift z    @xt    m     c     ,     ]     k     p     v     .     /
  @ctrl @alt @spcm  @fnum @spcm_tap
)

(deflayer graphite_rise_test
`
  caps 1     2     3     4     5     6     7     8     @,s  ;    -
  tab  b     l     d     w     q     [     '     f     o     u     j     S-;   S-'
  @csc  n     r     t     s     g     ;     y     h     a     e     i     @⏎
  @shift z    @xt    m     c     ,     ]     k     p     v     .     /
  @ctrl @alt @spcm  @fnum @spcm_tap
)

(deflayer qwerty_dispaced
  `
 caps 1     2     3     4     5     6     7     8     9     0     -
 tab  q     w     e     r     t     [     y     u     i     o     p     ⏎     \
 @csc  a     s     d     f     g     ⏎     h     j     k     l     ;     @'
 @shift z     x     c     v     b     ]     n     m     b     .     /
 lctrl lalt @spcm  @fnum ⏎
 )

(deflayer qwerty_ctrl
  `
 caps  C-j   C-k   C-k  4     5     6     7     8     9     0     -
 tab   C-y   C-u   C-o   C-h   C-'  [     y     u     i     o     p     ⏎     \
 @csc   C-a   C-e   C-i   C-f   C-j  ⏎     h     j     k     l     ;     @'
 @shift  C-z   C-x   C-c   C-v     b     ]     n     m     b     .     /
 lctrl lalt @spcm  @fnum ⏎
 )

(deflayer movesym
  `
  caps S-5   S-\   S-7   S-6   _     6     7     8     9     0     -
  S-,  S-1   S-.   S-9   S-0   [     [     ]     S-[   S-]   ⏎     ⇟     ⎀    ⎙ 
  @csc  +     S-8   -     =     S--   ⏎     ←     ↓     ↑     →     ⇥     ▤ 
  @shift S-`   S-5   S-6   /     XX    ]     ⇤     ⌫     ⌦     ⇞     \
  lctrl @alt @spcm  @fnum* ⏎
)

(deflayer movesym_
  `
  caps S-5   S-\   S-7   S-6   _     6     7     8     9     0     -
  S-,  S-1   S-.   S-9   S-0   [     ]     S-[   S-]   ⏎     ⇟     ⎀    ⎙      \
  @csc  +     S-8   -     =     S--   ←     ↓     ↑     →     ⇥     ▤    ⏎
  @shift S-`   S-5   S-6   /     XX    ⇤     ⌫     ⌦     ⇞     /   rshift
  lctrl @alt @spcm_  @fnum*_ ⏎
)

(deflayer fnum_
  `
  caps 1     2     3     4     5     6     7     @,s  9     0     -
  tab  f1    f2    f3    f4    f5    f6    f7    f8    f9    f10   f11   f12   \
  @csc  1     2     3     4     5     6     7     8     9     0     @000  ⏎
  @shift ,     +     =     -     S-6   S-5   S-8   ,     .     / rshift
  lctrl @alt @spcm  @fnum ⏎
)

(deflayer fnum
  `
  caps 1     2     3     4     5     6     7     @,s  9     0     -
  tab  f1    f2    f3    f4    f5    [     f6    f7    f8    f9    f10   f11   f12
  @csc  1     2     3     4     5     ⏎     6     7     8     9     0     @000
  @shift ,     +     =     -     S-6   ]     S-5   S-8   ,     .     /
  lctrl @alt @spcm_ @fnum_ ⏎
)

(deflayer extra
 mfwd
 caps C-⇞   C-⇟   mmid  4     5     6     7     8     9     0     -
 mbck mlft  mlft  @mA   mrgt  t     [     y     _     mute  vold  volu  ]     \
 @csc  @md   @m<   @mv   @m>   mfwd  ⏎     h     @tq   prev  pp    next  '
 @shift @mu   @md   @ml   @mr   b     ]     .     @tg   brdn  brup  /
 @tq @ts @tg @tq_ @tf
 )

(deflayer extra_
 mfwd
 caps C-⇞   C-⇟   mmid  4     5     6     7     8     9     0     -
 mbck mfwd  mlft  @mA   mrgt  t     y     _     mute  vold  volu   [    ]     \
 @csc  @md   @m<   @mv   @m>   mfwd  h     @tq   prev  pp    next  ' ret
 @shift @mu   @ml   @ml   @mr   b     .     @tg   brdn  brup  /  rshift
 @tq @ts @tg @tq_ @tf
 )

(deflayer emoji
  `
  caps 🔣🤝  🔣👍  🔣👎  🔣💡   🔣✅   -     6      7      8      9   0
  tab  🔣💙  🔣😂  🔣💀  🔣😉   🔣🇳🇵   🔣👇  🔣🧑‍🦽   🔣😮   🔣🙉   🔣🙌  🔣🙁   🔣🫶   🔣👆
  🔣🧠  🔣🙅  🔣🥀  🔣😆  🔣🙂   🔣👌   ⏎     🔣✌️   🔣💯   🔣🤭   🔣🔗   🔣🙇   🔣⚠️ 
  @shift 🔣🏃   🔣💨   🔣🙂  🔣🙃  🔣🫅  ]      🔣🤯   🔣🙏   🔣🧲   🔣👏  🔣🤛
  lctrl lalt @spcm  @fnum ⏎
)


(deflayer tapio_expanded
  0
  esc   @q    @w    @e    @r    @t     6     7     8     9     0    -
  tab   @a    @s    @d    @f    @g    d     u     i     o     p     [     ]     \
  @csc   @z    @x    @c    @v    @b    h     j     k     l     ;     '    @_⏎
  @shift  @1    @2    @3    @4    '     n     m     ,     .     /    rshift
  lctrl @alt3 @spcl2  @fnum_ ⏎
)

(deflayer tapio_expanded_l2
  0
  esc   6     7     8     9     @000  6     7     8     9     0    -
  S-,  S-1   S-.   S-9   S-0     `     d     u     i     o     p     [     ]     \
  @csc     +     S-8   -      =   S--   h     j     k     l     ;     '    @_⏎
  @shift    S-`     ;     [      ]   b     n     m     ,     .     /    rshift
  lctrl @alt3 @spcl2  @fnum_ ⏎
)

(deflayer tapio_expanded_l3
  mute
  esc   volu  prev  pp    next  brup  6     7     8     9     0    -
  tab    vold  S-[   ↑     S-]   brdn  d     u     i     o     p     [     ]     \
  @csc   ⇥     ←     ↓     →     ⇤     h     j     k     l     ;     '    @_⏎
  @shift  \     S-\   S-6   S-7   b     n     m     ,     .     /    rshift
  lctrl @alt3 @spcl2  @fnum_ ⏎
)

