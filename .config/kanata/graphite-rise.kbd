(defalias
  email (macro r o j g o s a i Digit0 Digit2 S-2 g m a i l . c o m)
  q(chord tapio_chords q)
  w(chord tapio_chords w)
  e(chord tapio_chords e)
  r(chord tapio_chords r)
  t(chord tapio_chords t)
  a(chord tapio_chords a)
  s(chord tapio_chords s)
  d(chord tapio_chords d)
  f(chord tapio_chords f)
  g(chord tapio_chords g)
  z(chord tapio_chords z)
  x(chord tapio_chords x)
  c(chord tapio_chords c)
  b(chord tapio_chords b)
  v(chord tapio_chords v)
  1(chord tapio_chords 1)
  2(chord tapio_chords 2)
  3(chord tapio_chords 3)
  4(chord tapio_chords 4)
  spcl2 (tap-hold 200 200 spc (layer-toggle tapio_expanded_l2))
  alt3 (
    tap-dance 300 (
      (tap-hold 100 100 (one-shot 1000 lshift) (layer-toggle tapio_expanded_l3))
      lalt
      caps
    )
  )
)
